.tab-bar {
    display: flex;
    flex-direction: row;
    background: #fff;
    border-top: 1rpx solid #e8e8e8;
    padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12rpx 0 8rpx;
}

.tab-icon {
    font-size: 44rpx;
    margin-bottom: 4rpx;
}

.tab-text {
    font-size: 20rpx;
    color: #999;
}

.tab-item.active .tab-text {
    color: #1890ff;
    font-weight: 600;
}
