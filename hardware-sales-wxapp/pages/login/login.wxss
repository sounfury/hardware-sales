.login-container {
    justify-content: center;
    padding: 0 40rpx;
    background: linear-gradient(180deg, #e6f7ff 0%, #f5f7fa 100%);
}

.header {
    align-items: center;
    margin-bottom: 80rpx;
}

.logo-text {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

.title {
    font-size: 40rpx;
    font-weight: bold;
    color: var(--text-main);
    margin-bottom: 16rpx;
}

.subtitle {
    font-size: 28rpx;
    color: var(--text-secondary);
}

.form-card {
    background: var(--bg-white);
    border-radius: 24rpx;
    padding: 60rpx 40rpx;
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.input-group {
    display: flex;
    flex-direction: column;
}

.label {
    font-size: 28rpx;
    color: var(--text-main);
    margin-bottom: 16rpx;
    font-weight: 500;
}

.input {
    height: 88rpx;
    background-color: var(--bg-color);
    border-radius: 12rpx;
    padding: 0 30rpx;
    font-size: 30rpx;
}

.login-btn {
    margin-top: 60rpx;
    height: 88rpx;
    line-height: 88rpx;
    font-size: 32rpx;
    width: 100%;
}