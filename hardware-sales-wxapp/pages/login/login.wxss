.login-container {
    justify-content: center;
    padding: 0 40rpx;
    background: linear-gradient(180deg, #e6f7ff 0%, #f5f7fa 100%);
}

.header {
    align-items: center;
    margin-bottom: 60rpx;
}

.logo-text {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

.title {
    font-size: 40rpx;
    font-weight: bold;
    color: var(--text-main);
    margin-bottom: 16rpx;
}

.subtitle {
    font-size: 26rpx;
    color: var(--text-secondary);
    text-align: center;
    padding: 0 10rpx;
    line-height: 1.5;
}

.form-card {
    background: var(--bg-white);
    border-radius: 24rpx;
    padding: 60rpx 40rpx;
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

/* 登录/注册 模式切换 */
.mode-switch {
    display: flex;
    background: #f0f5ff;
    border-radius: 999rpx;
    padding: 8rpx;
    margin-bottom: 36rpx;
}

.mode-item {
    flex: 1;
    text-align: center;
    line-height: 72rpx;
    border-radius: 999rpx;
    color: var(--text-secondary);
    font-size: 28rpx;
}

.mode-item.active {
    background: #1890ff;
    color: #fff;
    font-weight: 600;
}

/* 注册类型切换：客户 / 供应商 */
.register-type-switch {
    display: flex;
    gap: 16rpx;
    margin-bottom: 36rpx;
}

.type-btn {
    flex: 1;
    text-align: center;
    line-height: 72rpx;
    border-radius: 12rpx;
    font-size: 26rpx;
    color: var(--text-secondary);
    border: 2rpx solid var(--border-color);
    background: var(--bg-color);
}

.type-btn.type-active {
    border-color: #1890ff;
    color: #1890ff;
    background: #e6f7ff;
    font-weight: 600;
}

/* 输入项 */
.input-group {
    display: flex;
    flex-direction: column;
}

.label {
    font-size: 28rpx;
    color: var(--text-main);
    margin-bottom: 16rpx;
    font-weight: 500;
}

.input {
    height: 88rpx;
    background-color: var(--bg-color);
    border-radius: 12rpx;
    padding: 0 30rpx;
    font-size: 30rpx;
}

.login-btn {
    margin-top: 60rpx;
    height: 88rpx;
    line-height: 88rpx;
    font-size: 32rpx;
    width: 100%;
}

.register-tip {
    margin-top: 20rpx;
    font-size: 24rpx;
    line-height: 1.6;
    color: var(--text-secondary);
}

.customer-tip {
    color: #52c41a;
}

.switch-tip {
    margin-top: 28rpx;
    text-align: center;
    font-size: 26rpx;
    color: var(--text-secondary);
}

.switch-link {
    margin-left: 10rpx;
    color: #1890ff;
    font-weight: 600;
}