<view class="container login-container flex-col">
    <view class="header flex-col">
        <view class="logo-text">🔧</view>
        <view class="title">五金供应商终端</view>
        <view class="subtitle">{{mode === 'login' ? '欢迎回来，请登录您的账号' : '先注册账号，再提交供货商申请'}}</view>
    </view>
    <view class="form-card flex-col">
        <view class="mode-switch">
            <view class="mode-item {{mode === 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">登录</view>
            <view class="mode-item {{mode === 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode">注册</view>
        </view>
        <view class="input-group">
            <view class="label">账号</view>
            <input class="input" placeholder="请输入账号" value="{{username}}" data-field="username" bindinput="handleInput" />
        </view>
        <view class="input-group mt-md">
            <view class="label">密码</view>
            <input class="input" password placeholder="请输入密码" value="{{password}}" data-field="password" bindinput="handleInput" />
        </view>
        <view wx:if="{{mode === 'register'}}">
            <view class="input-group mt-md">
                <view class="label">确认密码</view>
                <input class="input" password placeholder="请再次输入密码" value="{{confirmPassword}}" data-field="confirmPassword" bindinput="handleInput" />
            </view>
            <view class="input-group mt-md">
                <view class="label">昵称（选填）</view>
                <input class="input" placeholder="请输入昵称" value="{{nickname}}" data-field="nickname" bindinput="handleInput" />
            </view>
            <view class="input-group mt-md">
                <view class="label">手机号（选填）</view>
                <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" data-field="phone" bindinput="handleInput" />
            </view>
            <view class="register-tip">注册成功后身份为空，需要在“我的”页面提交供货商资料并等待审核。</view>
        </view>
        <button class="btn-primary login-btn" bindtap="handleSubmit" loading="{{loading}}">
            {{mode === 'login' ? '登录' : '注册并继续'}}
        </button>
        <view class="switch-tip">
            <text>{{mode === 'login' ? '还没有账号？' : '已有账号？'}}</text>
            <text class="switch-link" data-mode="{{mode === 'login' ? 'register' : 'login'}}" bindtap="switchMode">
                {{mode === 'login' ? '去注册' : '去登录'}}
            </text>
        </view>
    </view>
</view>
