<view class="container login-container flex-col">
    <view class="header flex-col">
        <view class="logo-text">🔧</view>
        <view class="title">五金供应商终端</view>
        <view class="subtitle">欢迎回来，请登录您的账号</view>
    </view>
    <view class="form-card flex-col">
        <view class="input-group">
            <view class="label">账号</view>
            <input class="input" placeholder="请输入账号" model:value="{{username}}" />
        </view>
        <view class="input-group mt-md">
            <view class="label">密码</view>
            <input class="input" password placeholder="请输入密码" model:value="{{password}}" />
        </view>
        <button class="btn-primary login-btn" bindtap="handleLogin" loading="{{loading}}">
            登录
        </button>
    </view>
</view>