.quote-add-container {
    padding-bottom: 40rpx;
}

.search-bar {
    background: var(--bg-white);
    padding: 20rpx 40rpx;
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
}

.search-input {
    flex: 1;
    height: 72rpx;
    background: var(--bg-color);
    border-radius: 36rpx;
    padding: 0 80rpx 0 40rpx;
    font-size: 28rpx;
}

.search-icon {
    position: absolute;
    right: 60rpx;
    font-size: 32rpx;
    padding: 10rpx;
}

.step-title {
    padding: 20rpx 10rpx;
    color: var(--text-secondary);
    font-size: 28rpx;
}

.list {
    padding: 0 30rpx 40rpx;
}

.product-card {
    background: var(--bg-white);
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.product-name {
    font-size: 32rpx;
    font-weight: bold;
}

.tag {
    font-size: 20rpx;
    background: var(--bg-color);
    color: var(--text-secondary);
    padding: 4rpx 12rpx;
    border-radius: 8rpx;
    vertical-align: middle;
    margin-left: 10rpx;
    font-weight: normal;
}

.select-btn {
    background: #e6f7ff;
    color: var(--primary-color);
    border: 1rpx solid #91caff;
    padding: 8rpx 24rpx;
    border-radius: 26rpx;
    font-size: 26rpx;
    margin-left: 20rpx;
}

.load-more {
    text-align: center;
    padding: 30rpx 0;
}

.empty-state {
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
}

.empty-icon {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

/* 步骤二 */
.selected-product-card {
    background: var(--primary-color);
    color: #fff;
    padding: 40rpx 40rpx;
    position: relative;
}

.selected-product-card .spec {
    color: rgba(255, 255, 255, 0.8);
}

.change-btn {
    position: absolute;
    right: 40rpx;
    top: 40rpx;
    background: rgba(255, 255, 255, 0.2);
    padding: 8rpx 20rpx;
    border-radius: 26rpx;
    font-size: 24rpx;
}

.form-card {
    background: var(--bg-white);
    padding: 0 30rpx 30rpx;
}

.form-title {
    font-size: 32rpx;
    font-weight: bold;
    padding: 30rpx 0 10rpx;
    border-bottom: 1rpx solid var(--border-color);
    margin-bottom: 10rpx;
}

.form-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 1rpx solid var(--border-color);
}

.border-none {
    border-bottom: none;
}

.form-item-col {
    flex-direction: column;
    align-items: flex-start;
}

.label {
    width: 160rpx;
    font-size: 28rpx;
    color: var(--text-main);
}

.required {
    color: var(--danger-color);
    margin-right: 4rpx;
}

.input {
    flex: 1;
    font-size: 28rpx;
    text-align: right;
}

.form-item-col .label {
    margin-bottom: 20rpx;
}

.textarea {
    width: 100%;
    height: 160rpx;
    font-size: 28rpx;
    background-color: var(--bg-color);
    border-radius: 8rpx;
    padding: 20rpx;
    box-sizing: border-box;
}

.bottom-action {
    padding: 40rpx;
}

.submit-btn {
    width: 100%;
    height: 88rpx;
    line-height: 88rpx;
    font-size: 32rpx;
    border-radius: 8rpx;
}