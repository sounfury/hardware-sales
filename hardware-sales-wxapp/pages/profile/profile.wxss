.profile-container {
    padding-bottom: 40rpx;
}

.status-banner {
    padding: 30rpx 40rpx;
    display: flex;
    align-items: flex-start;
    color: #fff;
}

.status-banner.pending {
    background-color: var(--warning-color);
}

.status-banner.approved {
    background-color: var(--success-color);
}

.status-banner.rejected {
    background-color: var(--danger-color);
}

.status-icon {
    font-size: 40rpx;
    margin-right: 20rpx;
    margin-top: 4rpx;
}

.status-content {
    flex: 1;
}

.status-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 8rpx;
}

.status-desc {
    font-size: 26rpx;
    opacity: 0.9;
}

.form-card {
    background: var(--bg-white);
    padding: 0 30rpx 30rpx;
    margin-top: 20rpx;
}

.form-title {
    font-size: 32rpx;
    font-weight: bold;
    padding: 30rpx 0 10rpx;
    border-bottom: 1rpx solid var(--border-color);
    margin-bottom: 10rpx;
}

.form-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 1rpx solid var(--border-color);
}

.form-item-col {
    flex-direction: column;
    align-items: flex-start;
}

.label {
    width: 160rpx;
    font-size: 28rpx;
    color: var(--text-main);
}

.required {
    color: var(--danger-color);
    margin-right: 4rpx;
}

.input {
    flex: 1;
    font-size: 28rpx;
    text-align: right;
}

.form-item-col .label {
    margin-bottom: 20rpx;
}

.textarea {
    width: 100%;
    height: 160rpx;
    font-size: 28rpx;
    background-color: var(--bg-color);
    border-radius: 8rpx;
    padding: 20rpx;
    box-sizing: border-box;
}

.submit-btn {
    width: 100%;
    border-radius: 8rpx;
    margin-top: 40rpx;
}

.action-card {
    margin-top: 30rpx;
    background: var(--bg-white);
}

.logout-btn {
    background: var(--bg-white);
    color: var(--danger-color);
    font-size: 30rpx;
    font-weight: normal;
    border-radius: 0;
}