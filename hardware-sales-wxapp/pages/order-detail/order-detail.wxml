<view class="container order-detail-container" wx:if="{{!loading && order}}">
    <view class="status-header {{order.statusClass}}">
        <text class="status-icon-lg">{{order.paymentStatus === 0 ? '⏳' : '✅'}}</text>
        <text class="status-text-lg">{{order.statusText}}</text>
        <text class="status-sub">{{order.paymentStatus === 0 ? '等待商家线下收款后完成结算' : '已完成结算'}}</text>
    </view>
    <view class="card info-card">
        <view class="card-title">订单信息</view>
        <view class="info-row flex-row justify-between">
            <text class="info-label">订单号</text>
            <text class="info-value text-sm">{{order.orderNo}}</text>
        </view>
        <view class="info-row flex-row justify-between">
            <text class="info-label">下单日期</text>
            <text class="info-value">{{order.orderDate}}</text>
        </view>
        <view class="info-row flex-row justify-between">
            <text class="info-label">客户名称</text>
            <text class="info-value">{{order.customerName}}</text>
        </view>
        <view class="info-row flex-row justify-between" wx:if="{{order.customerPhone}}">
            <text class="info-label">联系电话</text>
            <text class="info-value">{{order.customerPhone}}</text>
        </view>
        <view class="info-row flex-row justify-between" wx:if="{{order.remark}}">
            <text class="info-label">备注</text>
            <text class="info-value">{{order.remark}}</text>
        </view>
    </view>
    <view class="card items-card">
        <view class="card-title">商品明细</view>
        <view class="item-row flex-row justify-between" wx:for="{{order.items}}" wx:key="id">
            <view class="item-left flex-row">
                <view class="item-icon">🔩</view>
                <view class="item-info">
                    <view class="item-name">{{item.productName}}</view>
                    <view class="item-unit text-sm">单价：¥{{item.price}}</view>
                </view>
            </view>
            <view class="item-right">
                <view class="item-qty text-sm">×{{item.quantity}}</view>
                <view class="item-amount">¥{{item.amount}}</view>
            </view>
        </view>
    </view>
    <view class="card total-card flex-row justify-between">
        <text class="total-label">合计金额</text>
        <text class="total-value">¥{{order.totalAmount}}</text>
    </view>
</view>
<view class="loading-state" wx:if="{{loading}}">加载中...</view>
