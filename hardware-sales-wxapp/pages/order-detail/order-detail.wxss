.order-detail-container { padding-bottom: 40rpx; }
.status-header { display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx 50rpx; }
.status-pending { background: linear-gradient(135deg, #fa8c16 0%, #faad14 100%); }
.status-settled { background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%); }
.status-icon-lg { font-size: 80rpx; margin-bottom: 16rpx; }
.status-text-lg { font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 10rpx; }
.status-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); }
.info-card, .items-card, .total-card { margin: 20rpx 30rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: var(--text-main); margin-bottom: 24rpx; padding-bottom: 16rpx; border-bottom: 2rpx solid var(--border-color); }
.info-row { align-items: flex-start; padding: 14rpx 0; border-bottom: 1rpx solid var(--bg-color); }
.info-label { font-size: 26rpx; color: var(--text-secondary); width: 140rpx; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: var(--text-main); text-align: right; flex: 1; }
.item-row { align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--bg-color); }
.item-row:last-child { border-bottom: none; }
.item-left { align-items: center; flex: 1; min-width: 0; }
.item-icon { font-size: 40rpx; background: #e6f7ff; width: 72rpx; height: 72rpx; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.item-info { min-width: 0; }
.item-name { font-size: 28rpx; color: var(--text-main); font-weight: 500; margin-bottom: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-right { text-align: right; flex-shrink: 0; margin-left: 16rpx; }
.item-qty { margin-bottom: 6rpx; }
.item-amount { font-size: 32rpx; font-weight: 700; color: #ff4d4f; }
.total-card { align-items: center; }
.total-label { font-size: 30rpx; font-weight: 600; color: var(--text-main); }
.total-value { font-size: 48rpx; font-weight: 700; color: #ff4d4f; }
.loading-state { display: flex; justify-content: center; padding: 200rpx 0; color: var(--text-secondary); font-size: 28rpx; }
