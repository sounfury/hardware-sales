<view class="container customer-profile-container">
    <view class="user-header">
        <view class="avatar-wrap"><text class="avatar-emoji">👤</text></view>
        <view class="user-name">{{user.nickname || user.username}}</view>
        <view class="user-badge">客户</view>
        <view class="user-phone text-sm" wx:if="{{user.phone}}">{{user.phone}}</view>
    </view>
    <view class="card info-card">
        <view class="info-row flex-row justify-between">
            <text class="info-label">账号</text>
            <text class="info-value">{{user.username}}</text>
        </view>
        <view class="info-row flex-row justify-between">
            <text class="info-label">昵称</text>
            <text class="info-value">{{user.nickname || '未设置'}}</text>
        </view>
        <view class="info-row flex-row justify-between">
            <text class="info-label">手机号</text>
            <text class="info-value">{{user.phone || '未设置'}}</text>
        </view>
    </view>
    <view class="card action-card">
        <view class="action-item flex-row justify-between" bindtap="goOrders">
            <view class="action-left flex-row">
                <text class="action-icon">📋</text>
                <text class="action-text">我的预定</text>
            </view>
            <text class="action-arrow">›</text>
        </view>
    </view>
    <view class="card logout-card">
        <button class="logout-btn" bindtap="handleLogout">退出登录</button>
    </view>
</view>
