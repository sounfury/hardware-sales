.customer-profile-container { padding-bottom: 40rpx; background: var(--bg-color); }
.user-header { background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%); padding: 60rpx 40rpx 50rpx; display: flex; flex-direction: column; align-items: center; }
.avatar-wrap { width: 140rpx; height: 140rpx; background: rgba(255,255,255,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20rpx; }
.avatar-emoji { font-size: 80rpx; }
.user-name { font-size: 38rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.user-badge { background: rgba(255,255,255,0.25); color: #fff; font-size: 22rpx; padding: 4rpx 20rpx; border-radius: 999rpx; margin-bottom: 12rpx; }
.user-phone { color: rgba(255,255,255,0.8); }
.info-card { margin: 24rpx 30rpx; }
.info-row { align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--bg-color); }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: var(--text-secondary); }
.info-value { font-size: 28rpx; color: var(--text-main); }
.action-card { margin: 0 30rpx 20rpx; }
.action-item { align-items: center; padding: 20rpx 0; }
.action-left { align-items: center; gap: 16rpx; }
.action-icon { font-size: 36rpx; }
.action-text { font-size: 30rpx; color: var(--text-main); }
.action-arrow { font-size: 36rpx; color: var(--text-secondary); }
.logout-card { margin: 0 30rpx; }
.logout-btn { width: 100%; height: 88rpx; line-height: 88rpx; font-size: 30rpx; color: #ff4d4f; background: #fff2f0; border-radius: 12rpx; text-align: center; }
.logout-btn::after { border: none; }
