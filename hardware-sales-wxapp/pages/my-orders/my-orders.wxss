.orders-container { background: var(--bg-color); padding-bottom: 30rpx; }
.order-list { padding: 24rpx 30rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.order-header { align-items: center; margin-bottom: 20rpx; }
.order-no { font-size: 24rpx; color: var(--text-secondary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-right: 12rpx; }
.status-badge { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 999rpx; flex-shrink: 0; font-weight: 600; }
.status-pending { background: #fff7e6; color: #fa8c16; }
.status-settled { background: #f6ffed; color: #52c41a; }
.divider { height: 2rpx; background: var(--border-color); margin-bottom: 20rpx; }
.order-body { align-items: flex-start; margin-bottom: 16rpx; }
.order-amount-label, .order-date-label { font-size: 22rpx; color: var(--text-secondary); margin-bottom: 6rpx; }
.order-amount { font-size: 40rpx; font-weight: 700; color: #ff4d4f; }
.order-date-wrap { text-align: right; }
.order-date { font-size: 28rpx; color: var(--text-main); font-weight: 500; }
.order-remark { background: var(--bg-color); border-radius: 8rpx; padding: 10rpx 16rpx; margin-bottom: 16rpx; }
.order-footer { justify-content: flex-end; }
.view-detail { font-size: 26rpx; color: #1890ff; font-weight: 600; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: var(--text-main); font-weight: 600; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: var(--text-secondary); }
.load-more { text-align: center; padding: 30rpx 0; font-size: 24rpx; color: var(--text-secondary); }
